{
  "id": "lycheemem-tools",
  "name": "LycheeMem Tools",
  "description": "Thin OpenClaw adapter for LycheeMem structured long-term memory retrieval, synthesis, and background consolidation.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:8000"
      },
      "transport": {
        "type": "string",
        "enum": ["mcp", "http"],
        "default": "mcp"
      },
      "timeout": {
        "type": "number",
        "default": 120
      },
      "apiToken": {
        "type": "string",
        "default": ""
      }
    }
  },
  "skills": [
    "skills/lycheemem"
  ],
  "uiHints": {
    "baseUrl": {
      "label": "LycheeMem Base URL",
      "placeholder": "http://127.0.0.1:8000"
    },
    "transport": {
      "label": "Transport",
      "placeholder": "mcp"
    },
    "timeout": {
      "label": "Timeout Seconds",
      "placeholder": "120"
    },
    "apiToken": {
      "label": "API Token",
      "sensitive": true,
      "placeholder": "Bearer token for authenticated LycheeMem access"
    }
  }
}
