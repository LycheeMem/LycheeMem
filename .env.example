# LycheeMem .env 配置模板
# 复制为 .env 并填入真实值

# ─── LLM（litellm 统一格式：provider/model-name）───
# 格式说明：
#   OpenAI / 兼容代理：openai/<model>    例：openai/gpt-4o-mini
#   Gemini：           gemini/<model>    例：gemini/gemini-2.0-flash
#   Ollama：           ollama_chat/<model> 例：ollama_chat/qwen2.5
LLM_MODEL=
LLM_API_KEY=
LLM_API_BASE=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=0
LLM_TOP_P=0.80

# ─── Embedder（litellm 统一格式）───
EMBEDDING_BACKEND=litellm
EMBEDDING_MODEL=
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
# 共享本地 embedding 服务示例：
# python scripts/embedding_server.py --model Qwen/Qwen3-Embedding-0.6B --device cuda --port 8765
# EMBEDDING_BACKEND=http
# EMBEDDING_MODEL=local-embed
# EMBEDDING_SERVER_MODEL=Qwen/Qwen3-Embedding-0.6B
# EMBEDDING_API_BASE=http://localhost:8765

# ─── 工作记忆预算 ───
WM_MAX_TOKENS=128000
WM_WARN_THRESHOLD=0.7
WM_BLOCK_THRESHOLD=0.9

SQLITE_DB_PATH=data/sessions.db
SKILL_DB_PATH=data/skill_store.db
SKILL_VECTOR_DB_PATH=data/skill_vector
COMPACT_MEMORY_DB_PATH=data/compact_memory.db
COMPACT_VECTOR_DB_PATH=data/compact_vector
COMPOSITE_FILTER_ENABLED=false
ADEQUACY_CHECK_ENABLED=false

# ─── Semantic Reranker（可选，本地 CrossEncoder）───
RERANKER_ENABLED=false
RERANKER_BACKEND=local
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_API_BASE=
RERANKER_API_KEY=
RERANKER_DEVICE=auto
RERANKER_BATCH_SIZE=16
RERANKER_MAX_LENGTH=512
RERANKER_COMPOSITE_LIMIT=80
RERANKER_FALLBACK_LIMIT=100
# 共享 reranker 服务示例：
# python scripts/reranker_server.py --model BAAI/bge-reranker-v2-m3 --device cuda --port 8766
# RERANKER_ENABLED=true
# RERANKER_BACKEND=http
# RERANKER_API_BASE=http://localhost:8766

MIN_RECENT_TURNS=4
SKILL_TOP_K=3

# ─── 视觉记忆 / VLM（可选）───
# VLM 模型（留空则复用主 LLM），例如 openai/qwen-vl-max
VLM_MODEL=
VLM_API_KEY=
VLM_API_BASE=
VLM_TEMPERATURE=0.7
VLM_MAX_TOKENS=0
VLM_TOP_P=1.0

# 视觉记忆存储路径（通常无需修改）
VISUAL_MEMORY_DB_PATH=data/visual_memory.db
VISUAL_VECTOR_DB_PATH=data/visual_vector
VISUAL_IMAGE_PATH=data/visual_memory
