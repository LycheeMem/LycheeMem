# A-Frame .env 配置模板
# 复制为 .env 并填入真实值

# ─── LLM ───
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# ─── Embedder ───
EMBEDDING_BACKEND=openai          # openai 或 gemini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=              # 默认3072, 可选768/1536

# ─── 工作记忆预算 ───
WM_MAX_TOKENS=128000
WM_WARN_THRESHOLD=0.7
WM_BLOCK_THRESHOLD=0.9

# ─── 存储后端 ───
SESSION_BACKEND=sqlite            # memory | sqlite（默认 sqlite，嵌入式无需额外服务）
GRAPH_BACKEND=memory              # memory | neo4j（neo4j 需要单独部署）
SKILL_BACKEND=lancedb             # memory | lancedb（默认 lancedb，嵌入式无需额外服务）

SQLITE_DB_PATH=a_frame_sessions.db
LANCEDB_PATH=a_frame_lancedb

# ─── Neo4j (图谱持久化) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Redis (生产) ───
REDIS_URL=redis://localhost:6379/0

# ─── API 服务 ───
API_HOST=0.0.0.0
API_PORT=8000
