# LycheeMem .env 配置模板
# 复制为 .env 并填入真实值

# ─── LLM（litellm 统一格式：provider/model-name）───
# 格式说明：
#   OpenAI / 兼容代理：openai/<model>    例：openai/gpt-4o-mini
#   Gemini：           gemini/<model>    例：gemini/gemini-2.0-flash
#   Ollama：           ollama_chat/<model> 例：ollama_chat/qwen2.5
LLM_MODEL=
LLM_API_KEY=
LLM_API_BASE=

# ─── Embedder（litellm 统一格式）───
EMBEDDING_MODEL=
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# ─── 工作记忆预算 ───
WM_MAX_TOKENS=128000
WM_WARN_THRESHOLD=0.7
WM_BLOCK_THRESHOLD=0.9

SQLITE_DB_PATH=data/sessions.db
SKILL_DB_PATH=data/skill_store.db
SKILL_VECTOR_DB_PATH=data/skill_vector
COMPACT_MEMORY_DB_PATH=data/compact_memory.db
COMPACT_VECTOR_DB_PATH=data/compact_vector

MIN_RECENT_TURNS=4
SKILL_TOP_K=3

# ─── 视觉记忆 / VLM（可选）───
# VLM 模型（留空则复用主 LLM），例如 openai/qwen-vl-max
VLM_MODEL=
VLM_API_KEY=
VLM_API_BASE=

# 视觉记忆存储路径（通常无需修改）
VISUAL_MEMORY_DB_PATH=data/visual_memory.db
VISUAL_VECTOR_DB_PATH=data/visual_vector
VISUAL_IMAGE_PATH=data/visual_memory

# ─── Transformer reranker（默认开启，安全回退）───
# 安装 lycheemem[rerank] 后，系统会自动从 Hugging Face 下载 LycheeMem/reranker。
# 如果依赖或模型不可用，会自动回退到 baseline semantic search。
EXPERIMENTAL_TRANSFORMER_RERANK=true
TRANSFORMER_RERANK_MODEL_PATH=LycheeMem/reranker
TRANSFORMER_RERANK_MAX_REPLACEMENTS=1
TRANSFORMER_RERANK_MERGE_MARGIN=0.3
TRANSFORMER_RERANK_MIN_ENGINE_SCORE_DELTA=-1.0
TRANSFORMER_RERANK_WIDE_TOP_K=50
TRANSFORMER_RERANK_DEVICE=auto
