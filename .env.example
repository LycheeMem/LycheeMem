# LycheeMem .env 配置模板
# 复制为 .env 并填入真实值

# ─── LLM（litellm 统一格式：provider/model-name）───
# 格式说明：
#   OpenAI / 兼容代理：openai/<model>    例：openai/gpt-4o-mini
#   Gemini：           gemini/<model>    例：gemini/gemini-2.0-flash
#   Ollama：           ollama_chat/<model> 例：ollama_chat/qwen2.5
LLM_MODEL=
LLM_API_KEY=
LLM_API_BASE=

# ─── Embedder（litellm 统一格式）───
EMBEDDING_MODEL=
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# ─── 工作记忆预算 ───
WM_MAX_TOKENS=128000
WM_WARN_THRESHOLD=0.7
WM_BLOCK_THRESHOLD=0.9

SQLITE_DB_PATH=data/sessions.db
USER_DB_PATH=data/users.db
SKILL_FILE_PATH=data/skills.jsonl

NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

MIN_RECENT_TURNS=4
GRAPH_SEARCH_DEPTH=3
GRAPH_TOP_K=5
SKILL_TOP_K=3

# ─── API 服务 ───
API_HOST=0.0.0.0
API_PORT=8000
