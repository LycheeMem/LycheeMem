# LycheeMemOS .env 配置模板
# 复制为 .env 并填入真实值

# ─── LLM ───
OPENAI_API_KEY=sk-xxx
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# ─── Embedder ───
EMBEDDING_BACKEND=openai          # openai 或 gemini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=              # 默认3072, 可选768/1536

# ─── 工作记忆预算 ───
WM_MAX_TOKENS=128000
WM_WARN_THRESHOLD=0.7
WM_BLOCK_THRESHOLD=0.9

# ─── 存储后端 ───
SESSION_BACKEND=sqlite            # memory | sqlite（默认 sqlite，嵌入式无需额外服务）
GRAPH_BACKEND=memory              # memory | neo4j（neo4j 需要单独部署）
SKILL_BACKEND=file                # memory | file | lancedb（默认 file，单文件落盘，无额外依赖）

SQLITE_DB_PATH=lychee_memos_sessions.db
LANCEDB_PATH=lychee_memos_lancedb
SKILL_FILE_PATH=lychee_memos_skills.json

# ─── Neo4j (图谱持久化) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Graphiti(论文) 图谱引擎（PR2：Episode 写入） ───
# 开启后会额外连接 Neo4j 并初始化 Graphiti schema（约束/索引）。
GRAPHITI_ENABLED=false
GRAPHITI_DATABASE=neo4j

# ─── Redis (生产) ───
REDIS_URL=redis://localhost:6379/0

# ─── API 服务 ───
API_HOST=0.0.0.0
API_PORT=8000
