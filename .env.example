# LycheeMemOS .env 配置模板
# 复制为 .env 并填入真实值

# ─── LLM（litellm 统一格式：provider/model-name）───
# 格式说明：
#   OpenAI / 兼容代理：openai/<model>      例：openai/gpt-4o-mini
#   Gemini：           gemini/<model>      例：gemini/gemini-2.0-flash
#   Ollama（本地）：   ollama_chat/<model>  例：ollama_chat/qwen2.5
#
# LLM_API_KEY  为空时 litellm 自动读取 OPENAI_API_KEY / GEMINI_API_KEY 等标准 env var。
# LLM_API_BASE 为空时使用 provider 默认端点；自定义代理或 Ollama 需填写。
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=sk-xxx
LLM_API_BASE=                         # 可选；例：https://api-inference.modelscope.cn/v1

# ─── Embedder（litellm 统一格式）───
# 格式同 LLM_MODEL，例：
#   openai/text-embedding-3-small
#   gemini/gemini-embedding-001
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1024
EMBEDDING_API_KEY=                    # 可选；为空时复用 provider 标准 env var
EMBEDDING_API_BASE=                   # 可选

# ─── 工作记忆预算 ───
WM_MAX_TOKENS=128000
WM_WARN_THRESHOLD=0.7
WM_BLOCK_THRESHOLD=0.9

# ─── 存储后端 ───
SESSION_BACKEND=sqlite            # memory | sqlite（默认 sqlite，嵌入式无需额外服务）
GRAPH_BACKEND=memory              # memory | neo4j（neo4j 需要单独部署）
SKILL_BACKEND=file                # memory | file | lancedb（默认 file，单文件落盘，无额外依赖）

SQLITE_DB_PATH=lychee_memos_sessions.db
LANCEDB_PATH=lychee_memos_lancedb
SKILL_FILE_PATH=lychee_memos_skills.json

# ─── Neo4j (图谱持久化) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Graphiti(论文) 图谱引擎（PR2：Episode 写入） ───
# 开启后会额外连接 Neo4j 并初始化 Graphiti schema（约束/索引）。
GRAPHITI_ENABLED=false
GRAPHITI_DATABASE=neo4j

# ─── API 服务 ───
API_HOST=0.0.0.0
API_PORT=8000
