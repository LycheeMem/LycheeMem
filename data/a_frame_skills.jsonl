, 0.004834551, 0.003909494, 0.004020381, 0.0021022144, 0.0058546565, -0.02291546, -0.016275818, -0.004345199, -0.002041757, -0.016092515, 0.026166828, -0.0037843715, 0.007064372, 0.003895283, -0.00044320154, 0.022624735, -9.8793826e-05, 0.020158058, -0.020142201, -0.017713761, -0.0067504863, -0.0023970294, 0.020748785, 0.017926361, 0.0046208133, -0.0049910005, -0.013596775, 0.005595143, 0.041300125, -0.013764957, 0.03747928, -0.017463252, 0.009382553, -0.012479662, -0.0015939322, -0.023142673, 0.0069942926, 0.017065555, 0.027014641, -0.004270618, 0.0058506485, 0.019644815, 0.011332241], "doc_markdown": "# 露天长期停放车辆保养指南\n\n## 适用场景\n- 车辆需在户外长期停放（超过2周）的预防性维护。\n\n## 关键维护清单\n1. **电瓶管理**：每2周启动车辆怠速或行驶15-20分钟；若停放超1个月，断开电瓶负极。\n2. **车身保护**：使用高质量透气车衣，防止紫外线、鸟粪及灰尘雨水侵蚀。\n3. **轮胎维护**：保持胎压至标准上限；定期挪动车辆（改变受力点）。\n4. **燃油系统**：保持半箱油以上，防止油箱内壁产生冷凝水。\n5. **附件保养**：将雨刮器立起，避免橡胶条粘连；潮湿环境尽量减少手刹长时间紧固（配合轮挡使用）。", "metadata": {}, "success_count": 0, "last_used": null, "conditions": ""}, {"id": "1689d843-5b9e-4178-9dca-a853b6e48393", "intent": "针对过敏体质人群筛选安全伴手礼", "embedding": [-0.009323712, 0.001860305, 0.001512639, -0.06907532, -0.0076567316, -0.0020454153, -0.017943777, -0.0038236051, 0.007574051, -0.0066213747, 0.014126733, -0.018816946, -0.012587718, -0.0005729552, 0.12686776, -0.019934049, 0.013408148, 0.0053894906, 0.010312867, -0.03287442, -0.011686684, -0.010662993, 0.017179143, -0.045512635, -0.0044878656, -0.01945747, 0.022581078, 0.018210772, 0.011836468, 0.023014247, 0.010924833, 0.020664092, 0.024741303, 0.024488749, 0.00873099, -0.0026542365, 0.012170941, -0.015240611, 0.015538519, 0.011635898, -0.004778538, 0.021570317, 0.013286483, -0.011694766, -0.025262538, -0.008014814, 0.012468946, -0.023844961, 0.007372391, 0.011742638, 0.016866993, 0.02531594, -0.0031473578, -0.17012165, -0.017970068, 0.009082562, -0.012584094, 0.003507811, 0.004020768, -0.02009745, -0.030716427, 0.01988423, -0.005080709, -0.02179296, 0.0047752806, -0.0012880358, -0.017959984, -0.004827468, -0.0020680863, 0.003568